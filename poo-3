#include <iostream>
#include <vector>
#include <fstream>
#include <string>

using namespace std;

class IRezervare {
public:
    virtual int calculeazaDurata() const = 0;
    virtual double calculeazaPret() const = 0;
    virtual string getTip() const = 0;
    virtual ~IRezervare() {}
};

class Rezervare : public IRezervare {
protected:
    string numeClient;
    string dataOra;
    int nrPersoane;
public:
    Rezervare(string nume, string data, int nr) : numeClient(nume), dataOra(data), nrPersoane(nr) {}
    string getNume() const { return numeClient; }
    string getData() const { return dataOra; }
    int getNrPers() const { return nrPersoane; }
};

class RezervareZilnica : public Rezervare {
public:
    RezervareZilnica(string n, string d, int p) : Rezervare(n, d, p) {}
    string getTip() const override { return "Zilnica"; }
    int calculeazaDurata() const override { return 2; }
    double calculeazaPret() const override {
        if (nrPersoane <= 2) return 50.0;
        return 50.0 + (nrPersoane - 2) * 20.0;
    }
};

class RezervareEvenimentSpecial : public Rezervare {
public:
    RezervareEvenimentSpecial(string n, string d, int p) : Rezervare(n, d, p) {}
    string getTip() const override { return "Special"; }
    int calculeazaDurata() const override { return 5; }
    double calculeazaPret() const override {
        int oreExtra = calculeazaDurata() - 2;
        return 200.0 + oreExtra * 50.0;
    }
};

class RezervareGrupMare : public Rezervare {
public:
    RezervareGrupMare(string n, string d, int p) : Rezervare(n, d, p) {}
    string getTip() const override { return "Grup"; }
    int calculeazaDurata() const override { return 3; }
    double calculeazaPret() const override {
        double pret = 500.0;
        if (nrPersoane > 20) pret += (nrPersoane - 20) * 10.0;
        return pret;
    }
};

class RezervareVIP : public Rezervare {
public:
    RezervareVIP(string n, string d, int p) : Rezervare(n, d, p) {}
    string getTip() const override { return "VIP"; }
    int calculeazaDurata() const override { return 4; }
    double calculeazaPret() const override {
        double pret = 1000.0;
        if (nrPersoane > 5) pret += (nrPersoane - 5) * 100.0;
        return pret;
    }
};

