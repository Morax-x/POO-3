        f << "VIP MariaIonescu 2025-03-10_20:00 5\n";
        f.close();
    }
}

int main() {
    string numeFisier = "rezervari.txt";

    creeazaFisier(numeFisier);

    vector<Rezervare*> lista;
    ifstream fisier(numeFisier);

    if (!fisier.is_open()) {
        cout << "Eroare la deschiderea fisierului!" << endl;
        return 1;
    }

    string tip, nume, data;
    int nr;

    while (fisier >> tip >> nume >> data >> nr) {
        if (tip == "Zilnica") lista.push_back(new RezervareZilnica(nume, data, nr));
        else if (tip == "Special") lista.push_back(new RezervareEvenimentSpecial(nume, data, nr));
        else if (tip == "Grup") lista.push_back(new RezervareGrupMare(nume, data, nr));
        else if (tip == "VIP") lista.push_back(new RezervareVIP(nume, data, nr));
    }

    fisier.close();

    cout << "TIP\tCLIENT\t\tPERS\tDURATA\tPRET\n";
    cout << "---------------------------------------------\n";

    for (auto r : lista) {
        cout << r->getTip() << "\t";
        cout << r->getNume() << "\t\t";
        cout << r->getNrPers() << "\t";
        cout << r->calculeazaDurata() << "\t";
        cout << r->calculeazaPret() << " MDL\n";
    }

    for (auto r : lista) delete r;

    return 0;
}
